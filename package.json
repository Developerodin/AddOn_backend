{
  "name": "node-template-server",
  "version": "1.0.0",
  "description": "Its an backend server template ",
  "bin": "bin/createNodejsApp.js",
  "main": "src/index.js",
  "author": "Akshay Pareek",
  "engines": {
    "node": ">=12.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "test": "jest -i --colors --verbose --detectOpenHandles",
    "test:esm": "cross-env NODE_OPTIONS=--experimental-vm-modules jest -i --colors --verbose --detectOpenHandles",
    "test:watch": "jest -i --watchAll",
    "coverage": "jest -i --coverage",
    "coverage:coveralls": "jest -i --coverage --coverageReporters=text-lcov | coveralls",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check **/*.js",
    "prettier:fix": "prettier --write **/*.js",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:test": "docker-compose -f docker-compose.yml -f docker-compose.test.yml up",
    "migrate:navigation": "cross-env NODE_ENV=development node update-user-navigation.js",
    "check:navigation": "cross-env NODE_ENV=development node check-user-navigation.js",
    "seed:storage-slots": "node src/scripts/seed-storage-slots.js",
    "seed:vendor-secondary-checking": "node src/scripts/seed-vendor-order-to-secondary-checking.js",
    "test:vendor-production-flow-containers": "cross-env NODE_ENV=development node src/scripts/test-vendor-production-flow-containers-e2e.js",
    "seed:machine-order-assignments": "node src/scripts/seed-machine-order-assignments.js",
    "report:yarn-inventory": "cross-env NODE_ENV=development node src/scripts/report-yarn-inventory.js",
    "report:yarn-stocked": "cross-env NODE_ENV=development node src/scripts/report-yarn-stocked.js",
    "report:yarn-boxes-po": "cross-env NODE_ENV=development node src/scripts/report-yarn-boxes-by-po.js",
    "report:yarn-box-excel-mismatch": "cross-env NODE_ENV=development node src/scripts/report-yarn-box-excel-mismatch.js --file=\"./7+2 Boxes Mis Match.xlsx\"",
    "report:cone-issue-from-xlsx": "cross-env NODE_ENV=development node src/scripts/report-cone-issue-from-xlsx.js --xlsx=\"./Short Term Yarn Return.xlsx\"",
    "report:yarn-storage-opening": "cross-env NODE_ENV=development node src/scripts/report-yarn-storage-opening.js",
    "report:yarn-snapshot-coverage": "cross-env NODE_ENV=development node src/scripts/report-yarn-daily-snapshot-coverage.js",
    "summarize:yarn-inventory": "cross-env NODE_ENV=development node src/scripts/yarn-inventory-summary.js",
    "compare:yarn-physical-vs-inventory": "cross-env NODE_ENV=development node src/scripts/yarn-physical-vs-inventory-compare.js",
    "check:yarn-lt-st-barcode": "cross-env NODE_ENV=development node src/scripts/check-yarn-lt-st-by-barcode.js",
    "audit:yarn-lt-st-recon": "cross-env NODE_ENV=development node src/scripts/audit-yarn-lt-st-weight-reconciliation.js",
    "audit:yarn-lt-st-recon:csv": "cross-env NODE_ENV=development node src/scripts/audit-yarn-lt-st-weight-reconciliation.js --output-csv=./yarn-lt-st-audit.csv",
    "report:storage-inventory": "node src/scripts/compare-storage-inventory-apis.js",
    "test:moa-audit": "cross-env NODE_ENV=test node scripts/verify-machine-order-assignment-audit.mjs",
    "test:moa-audit-jest": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest tests/integration/machineOrderAssignmentAudit.test.js -i --colors --verbose",
    "test:activity-logs": "cross-env NODE_ENV=development node scripts/test-user-activity-logs.js",
    "test:production-flow": "cross-env NODE_ENV=development node scripts/test-production-flow-branding-finalchecking.js",
    "test:partial-transfer": "cross-env NODE_ENV=development node scripts/test-partial-transfer-branding-finalchecking.js",
    "test:full-flow-20-80": "cross-env NODE_ENV=development node scripts/test-full-flow-branding-20-80-finalchecking.js",
    "seed:order-to-branding": "cross-env NODE_ENV=development API_URL=http://localhost:8000 node scripts/seed-order-to-branding.js",
    "migrate:containers-type-tearweight": "node src/scripts/update-containers-type-tearweight.js",
    "migrate:yarn-catalog-id": "cross-env NODE_ENV=development node src/scripts/migrate-yarn-to-yarnCatalogId.js",
    "migrate:cone-mark-used": "cross-env NODE_ENV=development node src/scripts/migrate-cone-mark-used.js",
    "migrate:backfill-final-checking-received": "cross-env NODE_ENV=development node src/scripts/backfill-final-checking-received-data-from-branding.js",
    "sync:yarn-labels-from-catalog": "cross-env NODE_ENV=development node src/scripts/sync-yarn-labels-from-catalog.js",
    "verify:yarn-catalog-names": "cross-env NODE_ENV=development node src/scripts/verify-yarn-catalog-yarn-names.js",
    "boxes:zero-out-from-excel": "cross-env NODE_ENV=development node src/scripts/zero-out-yarn-boxes-from-excel.js",
    "cones:mark-used-from-excel": "cross-env NODE_ENV=development node src/scripts/mark-yarn-cones-used-from-excel.js",
    "prepare": "husky install"
  },
  "keywords": [
    "node",
    "node.js",
    "boilerplate",
    "generator",
    "express",
    "rest",
    "api",
    "mongodb",
    "mongoose",
    "es6",
    "es7",
    "es8",
    "es9",
    "jest",
    "travis",
    "docker",
    "passport",
    "joi",
    "eslint",
    "prettier"
  ],
  "dependencies": {
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cron": "^4.3.3",
    "cross-env": "^7.0.0",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-mongo-sanitize": "^2.0.0",
    "express-rate-limit": "^5.0.0",
    "helmet": "^4.1.0",
    "http-status": "^1.4.0",
    "husky": "7.0.4",
    "joi": "^17.3.0",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.24.0",
    "mongoose": "^5.7.7",
    "morgan": "^1.9.1",
    "multer": "^2.0.1",
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^6.3.1",
    "openai": "^5.16.0",
    "passport": "^0.4.0",
    "passport-jwt": "^4.0.0",
    "pm2": "^5.1.0",
    "swagger-jsdoc": "^6.0.8",
    "swagger-ui-express": "^4.1.6",
    "uuid": "^11.1.0",
    "validator": "^13.0.0",
    "winston": "^3.2.1",
    "xlsx": "^0.18.5",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express-rate-limit": "^5.1.3",
    "@types/faker": "^6.6.8",
    "coveralls": "^3.0.7",
    "eslint": "^7.0.0",
    "eslint-config-airbnb-base": "^14.0.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-import": "^2.18.2",
    "eslint-plugin-jest": "^24.0.1",
    "eslint-plugin-prettier": "^3.1.1",
    "eslint-plugin-security": "^1.4.0",
    "faker": "^5.1.0",
    "jest": "^26.0.1",
    "lint-staged": "^11.0.0",
    "node-mocks-http": "^1.8.0",
    "nodemon": "^2.0.0",
    "prettier": "^2.0.5",
    "supertest": "^6.0.1"
  },
  "type": "module"
}
